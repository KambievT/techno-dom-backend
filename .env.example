# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database (SQLite — no extra setup needed)
DATABASE_URL="file:./dev.db"

# MinIO (run via docker-compose)
MINIO_ENDPOINT=localhost
